<button type="submit">Gönder</button>\n      </form>\n    </section>\n  </main>\n\n  <footer class="footer">\n    <p>© 2026 kediler için sosyal medya. Tüm hakları saklıdır.</p>\n  </footer>\n\n  <script src="script.js"></script>\n</body>\n</html>\n'}
