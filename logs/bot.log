content;\n  border: none;\n  border-radius: 10px;\n  padding: 10px 16px;\n  background: var(--accent);\n  color: #fff;\n  cursor: pointer;\n}\n\n.footer {\n  padding: 28px;\n  text-align: center;\n  color: var(--muted);\n}\n\n.reveal {\n  opacity: 0;\n  transform: translateY(16px);\n  transition: opacity 420ms ease, transform 420ms ease;\n}\n\n.reveal.visible {\n  opacity: 1;\n  transform: translateY(0);\n}\n\nbody.dark {\n  --bg: #111826;\n  --bg-strong: #0e1320;\n  --text: #f0f4fa;\n  --muted: #b8c1cf;\n  --accent: #22c55e;\n  --card: #161f31;\n  --border: #27334a;\n}\n'}
