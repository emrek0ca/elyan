ınız" required></textarea>\n        <button type="submit">Gönder</button>\n      </form>\n    </section>\n  </main>\n\n  <footer class="footer">\n    <p>© 2026 olarak siyah beyaz kullan renkleri. Tüm hakları saklıdır.</p>\n  </footer>\n\n  <script src="script.js"></script>\n</body>\n</html>\n'}
