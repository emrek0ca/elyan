[Unit]
Description=Elyan local-first personal agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=elyan
Group=elyan
EnvironmentFile=/srv/elyan/.env
WorkingDirectory=/srv/elyan/current/apps/web
ExecStart=pnpm start
Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
