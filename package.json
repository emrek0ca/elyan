{
  "name": "elyan",
  "version": "1.3.0",
  "description": "Elyan v1.3. Local-first personal agent runtime with guided setup, dashboard and CLI management, shared control plane, hosted surface, and app-connected operator.",
  "private": false,
  "license": "AGPL-3.0-or-later",
  "homepage": "https://elyan.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/emrek0ca/elyan.git"
  },
  "bugs": {
    "url": "https://github.com/emrek0ca/elyan/issues"
  },
  "bin": {
    "elyan": "bin/elyan.js"
  },
  "files": [
    "README.md",
    "LICENSE",
    "SECURITY",
    ".env.example",
    "Dockerfile",
    "bin",
    "docker-compose.yml",
    "next.config.ts",
    "searxng",
    "scripts",
    "src",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "file-type": "^22.0.1"
  },
  "keywords": [
    "ai",
    "agent",
    "local-first",
    "control-plane",
    "mcp",
    "ollama",
    "searxng",
    "llm",
    "privacy"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "node .next/standalone/server.js",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "lint": "eslint",
    "test": "vitest run",
    "test:control-plane": "vitest run tests/control-plane.test.ts",
    "test:capabilities": "vitest run tests/capabilities*.test.ts",
    "test:smoke": "vitest run tests/capabilities.smoke.test.ts",
    "mcp:validate": "vitest run tests/mcp.production.test.ts",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "security:check": "node scripts/security-check.js",
    "release:check": "node scripts/release-check.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/react": "^3.0.170",
    "@auth/pg-adapter": "^1.11.2",
    "@crawlee/cheerio": "^3.16.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@orama/orama": "^3.1.18",
    "@picovoice/cheetah-web": "^4.0.1",
    "@picovoice/cobra-web": "^3.0.0",
    "@picovoice/porcupine-web": "^4.0.0",
    "@picovoice/web-voice-processor": "^4.0.9",
    "ai": "^6.0.168",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "crawlee": "^3.16.0",
    "decimal.js": "^10.6.0",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.7.1",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "grammy": "^1.42.0",
    "jszip": "^3.10.1",
    "keyv": "^5.6.0",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "mathjs": "^15.2.0",
    "next": "15.5.15",
    "next-auth": "4.24.14",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "5.6.205",
    "pg": "^8.13.1",
    "playwright": "^1.59.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "unified": "^11.0.5",
    "unpdf": "^1.6.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
