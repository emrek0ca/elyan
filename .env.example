# Telegram Bot Configuration
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: Restrict bot access to specific user IDs (comma-separated)
# Leave empty to allow all users
# Get your user ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=

# Optional: Ollama Configuration
# Default: http://localhost:11434
# OLLAMA_HOST=http://localhost:11434

# Optional: Default model (auto-detected if not set)
# OLLAMA_MODEL=llama3.1:8b

# LLM Provider Selection
# Options: ollama (local), api (Google Gemini), groq (Groq Cloud - free & fast)
# LLM_TYPE=ollama

# Groq API Key (FREE - https://console.groq.com/keys)
# Ultra-fast LLM inference, recommended for best performance
# GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (FREE - https://aistudio.google.com/apikey)
# GOOGLE_API_KEY=your_google_api_key_here

# Phase 12.2: Morning Briefing Data Sources
# OpenWeatherMap API (free tier: https://openweathermap.org/api)
# OPENWEATHER_API_KEY=your_openweathermap_api_key_here
