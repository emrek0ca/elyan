# Elyan Environment Configuration
# Copy this file as .env and fill in your values
# NEVER commit .env with real credentials!

LLM_TYPE=ollama
FULL_DISK_ACCESS=true
# Gateway admin token (opsiyonel — yoksa /healthz'de otomatik üretilir)
ELYAN_ADMIN_TOKEN=
# Backend port (varsayılan: 18789)
ELYAN_PORT=18789
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
OLLAMA_HOST=http://localhost:11434
MODEL_NAME=llama3.1:8b
ALLOWED_USER_IDS=
GOOGLE_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Iyzico - Her plan icin dashboard'dan checkout URL al
IYZICO_WEBHOOK_SECRET=
IYZICO_PLAN_FREE_CHECKOUT_URL=
IYZICO_PLAN_PRO_CHECKOUT_URL=https://iyzi.co/xxxxx
IYZICO_PLAN_TEAM_CHECKOUT_URL=https://iyzi.co/xxxxx
IYZICO_PLAN_ENTERPRISE_CHECKOUT_URL=https://iyzi.co/xxxxx
IYZICO_TOKEN_PACK_STARTER_25K_CHECKOUT_URL=https://iyzi.co/xxxxx
IYZICO_TOKEN_PACK_GROWTH_100K_CHECKOUT_URL=https://iyzi.co/xxxxx
IYZICO_TOKEN_PACK_SCALE_500K_CHECKOUT_URL=https://iyzi.co/xxxxx
