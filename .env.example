# ── Elyan Ortam Yapılandırması ─────────────────────────────────────────────────
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env

# ── LLM Sağlayıcı (birini seçin) ─────────────────────────────────────────────

# 1) Ollama — ücretsiz, yerel, gizlilik odaklı (önerilen)
#    Kurulum: brew install ollama && ollama serve && ollama pull llama3.2:3b
OLLAMA_URL=http://localhost:11434
OLLAMA_HOST=http://localhost:11434
MODEL_NAME=llama3.2:3b

# 2) OpenAI (bulut)
OPENAI_API_KEY=

# 3) Anthropic Claude (bulut)
ANTHROPIC_API_KEY=

# 4) Google Gemini (bulut)
GOOGLE_API_KEY=

# 5) Groq — ücretsiz bulut API (hız öncelikliyse)
GROQ_API_KEY=

# ── Telegram Kanalı (opsiyonel) ───────────────────────────────────────────────
# Botunuzu @BotFather üzerinden alın
TELEGRAM_BOT_TOKEN=
# Kendi chat ID'nizi öğrenmek için @userinfobot'a mesaj gönderin
TELEGRAM_CHAT_ID=

# ── Elyan Güvenlik Ayarları ───────────────────────────────────────────────────
# Bağımsız paket kurulumu: 0=kapalı (üretim), 1=açık (geliştirme)
ELYAN_AUTO_INSTALL=0
# Deneysel öz-evrim modülleri: 0=kapalı (üretim), 1=açık (geliştirme)
ELYAN_GENESIS_ENABLED=0
# Gateway admin token (opsiyonel — yoksa /healthz'de otomatik üretilir)
ELYAN_ADMIN_TOKEN=
# Gateway portu
ELYAN_PORT=18789

# ── Local search / optional services ─────────────────────────────────────────
SEARXNG_URL=http://127.0.0.1:8080
