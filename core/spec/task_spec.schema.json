{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elyan.local/spec/task_spec.schema.json",
  "title": "Elyan TaskSpec",
  "type": "object",
  "required": [
    "task_id",
    "intent",
    "version",
    "goal",
    "user_goal",
    "entities",
    "deliverables",
    "constraints",
    "context_assumptions",
    "artifacts_expected",
    "checks",
    "rollback",
    "required_tools",
    "tool_candidates",
    "priority",
    "success_criteria",
    "risk_level",
    "timeouts",
    "retries",
    "steps"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "enum": [
        "filesystem_batch",
        "api_batch",
        "automation_batch",
        "office_batch",
        "coding_batch",
        "research_batch",
        "general_batch"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "user_goal": {
      "type": "string",
      "minLength": 1
    },
    "slots": {
      "type": "object"
    },
    "entities": {
      "type": "object"
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "kind",
          "required"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "file",
              "directory",
              "response",
              "report",
              "document",
              "artifact"
            ]
          },
          "required": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "object"
    },
    "context_assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts_expected": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "type",
          "must_exist"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "file",
              "directory"
            ]
          },
          "must_exist": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step_id",
          "checks"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "rollback": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "required_tools": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tool_candidates": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high",
        "critical"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "med",
        "high",
        "guarded",
        "dangerous"
      ]
    },
    "timeouts": {
      "type": "object",
      "required": [
        "step_timeout_s",
        "run_timeout_s"
      ],
      "properties": {
        "step_timeout_s": {
          "type": "integer",
          "minimum": 1
        },
        "run_timeout_s": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "retries": {
      "type": "object",
      "required": [
        "max_attempts"
      ],
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "action"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "params": {
            "type": "object"
          },
          "content": {
            "type": "string"
          },
          "expect_contains": {
            "type": "string"
          },
          "paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          },
          "success_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "anyOf": [
          {
            "required": [
              "path"
            ]
          },
          {
            "required": [
              "params"
            ]
          }
        ],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
